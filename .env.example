# Portal de Onboarding — template de variáveis de ambiente
# 1. Copie este arquivo: cp .env.example .env
# 2. Preencha com as chaves do seu projeto Supabase
# 3. Nunca commite o arquivo .env

# Supabase (Dashboard → Project Settings → API)
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=sua-chave-anon-aqui
VITE_SUPABASE_PUBLISHABLE_KEY=sua-chave-publishable-aqui

# Ambiente: development | staging | production
VITE_APP_ENV=development
